<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://example.org/pet-hospital.owl"
         xmlns="http://example.org/pet-hospital.owl#">

<owl:Ontology rdf:about="http://example.org/pet-hospital.owl"/>

<owl:ObjectProperty rdf:about="#owned_by">
  <rdfs:domain rdf:resource="#Animal"/>
  <rdfs:range rdf:resource="#Owner"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#treated_by">
  <rdfs:domain rdf:resource="#Animal"/>
  <rdfs:range rdf:resource="#Veterinarian"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_diagnosis">
  <rdfs:domain rdf:resource="#Animal"/>
  <rdfs:range rdf:resource="#Diagnosis"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#requires_treatment">
  <rdfs:domain rdf:resource="#Diagnosis"/>
  <rdfs:range rdf:resource="#Treatment"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#allergic_to">
  <rdfs:domain rdf:resource="#Animal"/>
  <rdfs:range rdf:resource="#Medication"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#uses_medication">
  <rdfs:domain rdf:resource="#Treatment"/>
  <rdfs:range rdf:resource="#Medication"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#has_name">
  <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#has_age">
  <rdfs:domain rdf:resource="#Animal"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#has_weight">
  <rdfs:domain rdf:resource="#Animal"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#is_vaccinated">
  <rdfs:domain rdf:resource="#Animal"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#has_specialty">
  <rdfs:domain rdf:resource="#Veterinarian"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#has_symptom">
  <rdfs:domain rdf:resource="#Diagnosis"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#has_severity">
  <rdfs:domain rdf:resource="#Diagnosis"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#Animal">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Person">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#MedicalRecord">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Medication">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Dog">
  <rdfs:subClassOf rdf:resource="#Animal"/>
</owl:Class>

<owl:Class rdf:about="#Cat">
  <rdfs:subClassOf rdf:resource="#Animal"/>
</owl:Class>

<owl:Class rdf:about="#Bird">
  <rdfs:subClassOf rdf:resource="#Animal"/>
</owl:Class>

<owl:Class rdf:about="#Veterinarian">
  <rdfs:subClassOf rdf:resource="#Person"/>
</owl:Class>

<owl:Class rdf:about="#Owner">
  <rdfs:subClassOf rdf:resource="#Person"/>
</owl:Class>

<owl:Class rdf:about="#Diagnosis">
  <rdfs:subClassOf rdf:resource="#MedicalRecord"/>
</owl:Class>

<owl:Class rdf:about="#Treatment">
  <rdfs:subClassOf rdf:resource="#MedicalRecord"/>
</owl:Class>

<owl:NamedIndividual rdf:about="#penicillin">
  <rdf:type rdf:resource="#Medication"/>
  <has_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">青霉素</has_name>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#amoxicillin">
  <rdf:type rdf:resource="#Medication"/>
  <has_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">阿莫西林</has_name>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#painkiller">
  <rdf:type rdf:resource="#Medication"/>
  <has_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">止痛药</has_name>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#dr_li">
  <rdf:type rdf:resource="#Veterinarian"/>
  <has_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">李医生</has_name>
  <has_specialty rdf:datatype="http://www.w3.org/2001/XMLSchema#string">骨科</has_specialty>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#dr_wang">
  <rdf:type rdf:resource="#Veterinarian"/>
  <has_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">王医生</has_name>
  <has_specialty rdf:datatype="http://www.w3.org/2001/XMLSchema#string">内科</has_specialty>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#zhang_san">
  <rdf:type rdf:resource="#Owner"/>
  <has_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">张三</has_name>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#li_si">
  <rdf:type rdf:resource="#Owner"/>
  <has_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">李四</has_name>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#wangcai">
  <rdf:type rdf:resource="#Dog"/>
  <owned_by rdf:resource="#zhang_san"/>
  <treated_by rdf:resource="#dr_li"/>
  <allergic_to rdf:resource="#penicillin"/>
  <has_diagnosis rdf:resource="#diag_wangcai_fracture"/>
  <has_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">旺财</has_name>
  <has_age rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</has_age>
  <has_weight rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">12.5</has_weight>
  <is_vaccinated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</is_vaccinated>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#mimi">
  <rdf:type rdf:resource="#Cat"/>
  <owned_by rdf:resource="#li_si"/>
  <treated_by rdf:resource="#dr_wang"/>
  <has_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">咪咪</has_name>
  <has_age rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</has_age>
  <has_weight rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">4.2</has_weight>
  <is_vaccinated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</is_vaccinated>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#dahuang">
  <rdf:type rdf:resource="#Dog"/>
  <owned_by rdf:resource="#zhang_san"/>
  <has_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">大黄</has_name>
  <has_age rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</has_age>
  <has_weight rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">28.0</has_weight>
  <is_vaccinated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</is_vaccinated>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#diag_wangcai_fracture">
  <rdf:type rdf:resource="#Diagnosis"/>
  <requires_treatment rdf:resource="#treat_fracture_surgery"/>
  <has_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">旺财的骨折诊断</has_name>
  <has_symptom rdf:datatype="http://www.w3.org/2001/XMLSchema#string">右前腿骨折</has_symptom>
  <has_severity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</has_severity>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#treat_fracture_surgery">
  <rdf:type rdf:resource="#Treatment"/>
  <uses_medication rdf:resource="#penicillin"/>
  <uses_medication rdf:resource="#painkiller"/>
  <has_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">骨折手术</has_name>
</owl:NamedIndividual>

<owl:AllDisjointClasses>
  <owl:members rdf:parseType="Collection">
    <rdf:Description rdf:about="#Dog"/>
    <rdf:Description rdf:about="#Cat"/>
    <rdf:Description rdf:about="#Bird"/>
  </owl:members>
</owl:AllDisjointClasses>


</rdf:RDF>
